@model CemaApp.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    body {
        background: #0f0f0f;
        font-family: 'Segoe UI', sans-serif;
        color: white;
    }

    .login-container {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 100%;
        max-width: 430px;
        background: #181818;
        border-radius: 20px;
        padding: 40px;
        border: 1px solid #262626;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }

    .login-title {
        font-size: 32px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 8px;
    }

    .login-subtitle {
        text-align: center;
        color: #9ca3af;
        margin-bottom: 35px;
        font-size: 14px;
    }

    .form-label {
        color: #d1d5db;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-control {
        background: #111111;
        border: 1px solid #2d2d2d;
        color: white;
        height: 50px;
        border-radius: 12px;
        padding: 10px 15px;
        transition: 0.3s;
    }

    .form-control:focus {
        background: #111111;
        color: white;
        border-color: #dc2626;
        box-shadow: none;
    }

    .form-check-label {
        color: #9ca3af;
    }

    .btn-login {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 12px;
        background: #dc2626;
        color: white;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-login:hover {
        background: #ef4444;
    }

    .register-link {
        text-align: center;
        margin-top: 20px;
        color: #9ca3af;
    }

    .register-link a {
        color: #dc2626;
        text-decoration: none;
        font-weight: 500;
    }

    .register-link a:hover {
        color: #ef4444;
    }

    .text-danger {
        font-size: 14px;
    }

</style>

<div class="login-container">
    <div class="login-card">

        <div class="login-title">
            Welcome Back
        </div>

        <div class="login-subtitle">
            Sign in to continue to CEMA Cinema
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn-login">
                Log in
            </button>

            <div class="register-link">
                Don't have an account?
                <a asp-action="Register">Register</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}