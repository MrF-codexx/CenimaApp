@model IEnumerable<CemaApp.Models.Hall>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Manage Halls</h1>
        <a asp-action="Create" class="btn btn-cema btn-lg"><i class="bi bi-plus-lg"></i> New Hall</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card bg-dark border-secondary h-100 shadow">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between">
                            <h3 class="fw-bold text-white mb-0">@item.Name</h3>
                            <span class="badge bg-danger">@item.Seats.Count Seats</span>
                        </div>
                        <hr class="border-secondary my-3">
                        <div class="row text-center">
                            <div class="col-6">
                                <p class="text-muted small mb-0">Rows</p>
                                <h4 class="fw-bold">@item.TotalRows</h4>
                            </div>
                            <div class="col-6">
                                <p class="text-muted small mb-0">Seats/Row</p>
                                <h4 class="fw-bold">@item.SeatsPerRow</h4>
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger w-100">Remove</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
