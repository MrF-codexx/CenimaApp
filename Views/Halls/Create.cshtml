@model CemaApp.Models.Hall

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card bg-dark border-secondary shadow-lg">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4">Add New Hall</h2>
                    <p class="text-muted mb-4">Defining a hall will automatically generate all individual seat records for you.</p>

                    <form asp-action="Create">
                        <div asp-validation-summary="All" class="text-danger mb-4"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label text-uppercase small fw-bold">Hall Name</label>
                            <input asp-for="Name" class="form-control bg-secondary text-white border-0 py-2" placeholder="e.g. IMAX Hall 1" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TotalRows" class="form-label text-uppercase small fw-bold">Total Rows</label>
                                <input asp-for="TotalRows" class="form-control bg-secondary text-white border-0 py-2" type="number" min="1" max="26" />
                                <span asp-validation-for="TotalRows" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SeatsPerRow" class="form-label text-uppercase small fw-bold">Seats Per Row</label>
                                <input asp-for="SeatsPerRow" class="form-control bg-secondary text-white border-0 py-2" type="number" min="1" />
                                <span asp-validation-for="SeatsPerRow" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-cema btn-lg flex-fill">Create Hall</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
