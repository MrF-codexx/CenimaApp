@model IEnumerable<CemaApp.Models.Movie>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<style>
    .clean-movie-card {
        background-color: #161616;
        border: 1px solid #262626;
        border-radius: 12px;
        transition: transform 0.2s ease, border-color 0.2s ease;
        overflow: hidden;
    }
    .clean-movie-card:hover {
        transform: translateY(-8px);
        border-color: #dc2626;
    }
    .movie-poster-img {
        height: 380px; 
        object-fit: cover; 
        width: 100%;
        border-bottom: 1px solid #262626;
    }
</style>

<div class="container-fluid px-lg-5 mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h2 class="fw-bold m-0">Now Showing</h2>
        
        <form asp-action="Index" method="get" class="d-flex gap-2 filter-bar">
            <div class="input-group input-group-sm" style="width: 250px;">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control bg-dark border-secondary text-white" placeholder="Search movies...">
            </div>
            
            <select name="genre" class="form-select form-select-sm bg-dark border-secondary text-white" style="width: 150px;">
                <option value="">All Genres</option>
                @foreach (var g in ViewBag.Genres)
                {
                    @if (g == ViewBag.CurrentGenre)
                    {
                        <option value="@g" selected>@g</option>
                    }
                    else
                    {
                        <option value="@g">@g</option>
                    }
                }
            </select>
            
            <button type="submit" class="btn btn-danger btn-sm px-3">Filter</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch) || !string.IsNullOrEmpty(ViewBag.CurrentGenre))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
            }
        </form>
    </div>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var movie in Model)
        {
            <div class="col">
                <div class="clean-movie-card h-100 shadow-sm">
                    <img src="/images/posters/@movie.PosterUrl" class="movie-poster-img" alt="@movie.Title">
                    <div class="card-body p-3 text-center">
                        <h6 class="fw-bold mb-1 text-truncate" title="@movie.Title">@movie.Title</h6>
                        <p class="text-muted small mb-3">@movie.Genre &bull; @movie.DurationMinutes min</p>
                        <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-danger btn-sm w-100 fw-bold">Book Now</a>
                        
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-1 mt-2">
                                <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-dark btn-sm flex-fill">Edit</a>
                                <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-outline-secondary btn-sm flex-fill">Delete</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center" data-bs-theme="dark">
                <li class="page-item @(!ViewBag.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" 
                       href="?searchString=@ViewBag.CurrentSearch&genre=@ViewBag.CurrentGenre&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                </li>
                
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == ViewBag.CurrentPage ? "bg-danger border-danger" : "bg-dark text-white border-secondary")" 
                           href="?searchString=@ViewBag.CurrentSearch&genre=@ViewBag.CurrentGenre&page=@i">@i</a>
                    </li>
                }

                <li class="page-item @(!ViewBag.HasNextPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" 
                       href="?searchString=@ViewBag.CurrentSearch&genre=@ViewBag.CurrentGenre&page=@(ViewBag.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search fs-1 text-muted d-block mb-3"></i>
            <h4 class="text-white">No movies found</h4>
            <p class="text-muted">Try adjusting your search or filters.</p>
            <a asp-action="Index" class="btn btn-outline-danger mt-2">Clear All Filters</a>
        </div>
    }
</div>