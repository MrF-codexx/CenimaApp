@model CemaApp.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-danger bg-dark text-light">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Are you sure you want to delete this movie?</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.PosterUrl))
                            {
                                <img src="/images/posters/@Model.PosterUrl" class="img-fluid rounded" alt="@Model.Title" />
                            }
                        </div>
                        <div class="col-md-8">
                            <h3 class="fw-bold text-danger">@Model.Title</h3>
                            <hr class="border-secondary" />
                            <dl class="row">
                                <dt class="col-sm-4 text-muted">Genre</dt>
                                <dd class="col-sm-8">@Model.Genre</dd>

                                <dt class="col-sm-4 text-muted">Duration</dt>
                                <dd class="col-sm-8">@Model.DurationMinutes mins</dd>

                                <dt class="col-sm-4 text-muted">Release Date</dt>
                                <dd class="col-sm-8">@Model.ReleaseDate.ToString("MMM dd, yyyy")</dd>
                            </dl>
                            
                            <div class="alert alert-warning text-dark mt-3">
                                <strong>Warning:</strong> This action cannot be undone. All associated image files will be permanently deleted from the server.
                            </div>

                            <form asp-action="Delete" method="post" class="mt-4">
                                <input type="hidden" asp-for="Id" />
                                <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
                                <a asp-action="Index" class="btn btn-outline-light ms-2">Cancel</a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>