@model CemaApp.Models.Screening

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card bg-dark border-danger shadow-lg p-5">
                <i class="bi bi-calendar-x display-1 text-danger mb-4"></i>
                <h2 class="fw-bold mb-3">Cancel Screening?</h2>
                <p class="text-muted mb-4">
                    Are you sure you want to cancel the screening of <strong>@Model.Movie.Title</strong> in <strong>@Model.Hall.Name</strong> at <strong>@Model.StartTime.ToString("HH:mm")</strong>?
                </p>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger btn-lg px-5">Cancel Showtime</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
